# Server
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# Database (SQLite for local dev)
DATABASE_URL="file:./dev.db"
# For PostgreSQL production:
# DATABASE_URL="postgresql://user:password@host:5432/columbiagorge?schema=public"

# JWT - generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# Stripe - get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Email (SMTP) - for Gmail, use an App Password not your account password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Email addresses
EMAIL_FROM="Columbia Gorge Getaways <no-reply@columbiagorgegetaways.com>"
EMAIL_ADMIN=admin@columbiagorgegetaways.com

# Initial admin account (used only by seed script)
ADMIN_EMAIL=admin@columbiagorgegetaways.com
ADMIN_PASSWORD=ChangeMe123!
